# Development-only defaults. Generate unique values for any shared or persistent environment.
POSTGRES_PASSWORD=kubequeue
KUBEQUEUE_API_PORT=8080
KUBEQUEUE_CORS_ALLOWED_ORIGINS=http://localhost:3000
KUBEQUEUE_DATABASE_URL=postgres://kubequeue:kubequeue@localhost:5432/kubequeue?sslmode=disable
KUBEQUEUE_API_INTERNAL_URL=http://localhost:8080
KUBEQUEUE_PUBLIC_URL=http://localhost:3000
KUBEQUEUE_BROWSER_ORIGIN=http://localhost:3000
KUBEQUEUE_LOG_LEVEL=info
KUBEQUEUE_WATCH_NAMESPACES=default
KUBEQUEUE_ENVIRONMENT=development

# These deterministic values are only for the local Compose stack.
KUBEQUEUE_SESSION_DIGEST_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
KUBEQUEUE_SESSION_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
KUBEQUEUE_SERVICE_ACCOUNT_DIGEST_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
KUBEQUEUE_BFF_INTERNAL_KEY=development-only-bff-key-00000000

# Local Compose binds to loopback and seeds admin/admin for immediate testing.
# Set false to exercise guarded first-time setup against a Kubernetes-enabled stack.
KUBEQUEUE_DEV_SEED_LOCAL_ADMIN=true
