{
  "name": "deploy",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "root": "deploy",
  "implicitDependencies": ["web", "control-plane"],
  "tags": ["type:deploy", "scope:platform"],
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "docker compose config --quiet",
          "docker compose run --rm --no-deps helm helm lint deploy/helm/kubequeue --set-string database.url=postgres://example --set-string config.adminToken=test-token",
          "docker compose run --rm --no-deps helm helm template kubequeue deploy/helm/kubequeue --set-string database.url=postgres://example --set-string config.adminToken=test-token",
          "docker compose run --rm --no-deps helm helm lint deploy/helm/kubequeue --set-string database.url=postgres://example --set-string config.adminToken=test-token --set-string watch.mode=all --set rbac.allowClusterWide=true",
          "docker compose run --rm --no-deps helm helm template kubequeue deploy/helm/kubequeue --set-string database.url=postgres://example --set-string config.adminToken=test-token --set-string watch.mode=all --set rbac.allowClusterWide=true"
        ],
        "parallel": false
      }
    },
    "dev-stack": {
      "executor": "nx:run-commands",
      "cache": false,
      "continuous": true,
      "options": {
        "command": "docker compose up --build --watch"
      }
    },
    "dev-down": {
      "executor": "nx:run-commands",
      "cache": false,
      "options": {
        "command": "docker compose down --remove-orphans"
      }
    },
    "dev-logs": {
      "executor": "nx:run-commands",
      "cache": false,
      "continuous": true,
      "options": {
        "command": "docker compose logs --follow"
      }
    },
    "dev-docs": {
      "executor": "nx:run-commands",
      "cache": false,
      "continuous": true,
      "options": {
        "command": "docker compose up api-docs"
      }
    },
    "helm-lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose run --rm --no-deps helm helm lint deploy/helm/kubequeue --set-string database.url=postgres://example --set-string config.adminToken=test-token"
      }
    },
    "helm-template": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose run --rm --no-deps helm helm template kubequeue deploy/helm/kubequeue --set-string database.url=postgres://example --set-string config.adminToken=test-token"
      }
    },
    "workflow-lint": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": [
        "{workspaceRoot}/.github/workflows/*.yml",
        "{workspaceRoot}/tools/check-workflows.mjs"
      ],
      "options": {
        "command": "node tools/check-workflows.mjs"
      }
    },
    "release-validate": {
      "executor": "nx:run-commands",
      "inputs": [
        "default",
        "^production",
        "{workspaceRoot}/compose.yaml",
        "{workspaceRoot}/tools/release-helm.mjs",
        { "env": "KUBEQUEUE_RELEASE_VERSION" }
      ],
      "outputs": ["{workspaceRoot}/dist/release"],
      "options": {
        "command": "node tools/release-helm.mjs validate"
      }
    },
    "helm-package": {
      "executor": "nx:run-commands",
      "inputs": [
        "default",
        "{workspaceRoot}/compose.yaml",
        "{workspaceRoot}/tools/release-helm.mjs",
        { "env": "KUBEQUEUE_RELEASE_VERSION" }
      ],
      "outputs": ["{workspaceRoot}/dist/kubequeue-*.tgz"],
      "options": {
        "command": "node tools/release-helm.mjs package"
      }
    },
    "chart-acceptance": {
      "executor": "nx:run-commands",
      "cache": false,
      "inputs": [
        "default",
        "^production",
        "{workspaceRoot}/apps/control-plane/Dockerfile",
        "{workspaceRoot}/apps/web/Dockerfile",
        "{workspaceRoot}/deploy/kind/postgres.yaml",
        "{workspaceRoot}/tools/deploy-acceptance.mjs"
      ],
      "options": {
        "command": "node tools/deploy-acceptance.mjs install"
      }
    },
    "chart-upgrade-acceptance": {
      "executor": "nx:run-commands",
      "cache": false,
      "inputs": [
        "default",
        "^production",
        "{workspaceRoot}/apps/control-plane/Dockerfile",
        "{workspaceRoot}/apps/web/Dockerfile",
        "{workspaceRoot}/deploy/kind/postgres.yaml",
        "{workspaceRoot}/tools/deploy-acceptance.mjs",
        { "env": "KUBEQUEUE_PREVIOUS_CHART" }
      ],
      "options": {
        "command": "node tools/deploy-acceptance.mjs upgrade"
      }
    },
    "chart-acceptance-teardown": {
      "executor": "nx:run-commands",
      "cache": false,
      "options": {
        "command": "node tools/deploy-acceptance.mjs teardown"
      }
    },
    "kind-create": {
      "executor": "nx:run-commands",
      "options": {
        "command": "kind create cluster --config deploy/kind/cluster.yaml"
      }
    },
    "kind-delete": {
      "executor": "nx:run-commands",
      "options": {
        "command": "kind delete cluster --name kubequeue"
      }
    },
    "tilt": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tilt up"
      }
    }
  }
}
