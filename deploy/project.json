{
  "name": "deploy",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "root": "deploy",
  "implicitDependencies": ["web", "control-plane"],
  "tags": ["type:deploy", "scope:platform"],
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "docker compose config --quiet",
          "docker compose run --rm --no-deps helm helm lint deploy/helm/kubequeue --set-string database.url=postgres://example",
          "docker compose run --rm --no-deps helm helm template kubequeue deploy/helm/kubequeue --set-string database.url=postgres://example"
        ],
        "parallel": false
      }
    },
    "dev-stack": {
      "executor": "nx:run-commands",
      "cache": false,
      "continuous": true,
      "options": {
        "command": "docker compose up --build --watch"
      }
    },
    "dev-down": {
      "executor": "nx:run-commands",
      "cache": false,
      "options": {
        "command": "docker compose down --remove-orphans"
      }
    },
    "dev-logs": {
      "executor": "nx:run-commands",
      "cache": false,
      "continuous": true,
      "options": {
        "command": "docker compose logs --follow"
      }
    },
    "dev-docs": {
      "executor": "nx:run-commands",
      "cache": false,
      "continuous": true,
      "options": {
        "command": "docker compose up api-docs"
      }
    },
    "helm-lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose run --rm --no-deps helm helm lint deploy/helm/kubequeue --set-string database.url=postgres://example"
      }
    },
    "helm-template": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose run --rm --no-deps helm helm template kubequeue deploy/helm/kubequeue --set-string database.url=postgres://example"
      }
    },
    "kind-create": {
      "executor": "nx:run-commands",
      "options": {
        "command": "kind create cluster --config deploy/kind/cluster.yaml"
      }
    },
    "kind-delete": {
      "executor": "nx:run-commands",
      "options": {
        "command": "kind delete cluster --name kubequeue"
      }
    },
    "tilt": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tilt up"
      }
    }
  }
}
