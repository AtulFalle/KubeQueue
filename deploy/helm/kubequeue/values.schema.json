{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": false,
      "required": ["create", "name"],
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" }
      }
    },
    "rbac": {
      "type": "object",
      "additionalProperties": false,
      "required": ["create", "allowClusterWide"],
      "properties": {
        "create": { "type": "boolean" },
        "allowClusterWide": { "type": "boolean" }
      }
    },
    "imagePullSecrets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "minLength": 1 }
        }
      }
    },
    "watch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "namespaces", "excludedNamespaces"],
      "properties": {
        "mode": { "type": "string", "enum": ["selected", "all"] },
        "namespaces": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/namespace" }
        },
        "excludedNamespaces": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/namespace" }
        }
      }
    },
    "config": {
      "type": "object",
      "additionalProperties": false,
      "required": ["globalConcurrency", "namespaceConcurrency"],
      "properties": {
        "globalConcurrency": { "type": "integer", "minimum": 1 },
        "namespaceConcurrency": { "type": "integer", "minimum": 1 }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["environment"],
      "properties": {
        "environment": {
          "type": "string",
          "enum": ["development", "test", "production"]
        }
      }
    },
    "development": {
      "type": "object",
      "additionalProperties": false,
      "required": ["localAdminSeed"],
      "properties": {
        "localAdminSeed": { "type": "boolean" }
      }
    },
    "browser": {
      "type": "object",
      "additionalProperties": false,
      "required": ["publicURL", "origin"],
      "properties": {
        "publicURL": { "$ref": "#/$defs/httpOrigin" },
        "origin": { "$ref": "#/$defs/httpOrigin" }
      }
    },
    "security": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "existingSecret",
        "sessionDigestKey",
        "credentialEncryptionKey",
        "bffInternalKey",
        "serviceAccountDigestKey"
      ],
      "properties": {
        "existingSecret": { "type": "string", "minLength": 1 },
        "sessionDigestKey": { "type": "string", "minLength": 1 },
        "credentialEncryptionKey": { "type": "string", "minLength": 1 },
        "bffInternalKey": { "type": "string", "minLength": 1 },
        "serviceAccountDigestKey": { "type": "string", "minLength": 1 }
      }
    },
    "database": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "existingSecret", "existingSecretKey"],
      "properties": {
        "url": { "type": "string" },
        "existingSecret": { "type": "string" },
        "existingSecretKey": { "type": "string", "minLength": 1 }
      }
    },
    "networkPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "properties": { "enabled": { "type": "boolean" } }
    },
    "api": { "$ref": "#/$defs/workloadWithPort" },
    "worker": { "$ref": "#/$defs/workload" },
    "web": { "$ref": "#/$defs/workloadWithPort" }
  },
  "required": [
    "api",
    "worker",
    "web",
    "serviceAccount",
    "rbac",
    "imagePullSecrets",
    "watch",
    "config",
    "runtime",
    "development",
    "browser",
    "security",
    "database",
    "networkPolicy"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "watch": {
            "properties": {
              "mode": { "const": "all" }
            }
          }
        }
      },
      "then": {
        "properties": {
          "rbac": {
            "properties": {
              "allowClusterWide": { "const": true }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "serviceAccount": {
            "properties": {
              "create": { "const": false }
            }
          }
        }
      },
      "then": {
        "properties": {
          "serviceAccount": {
            "properties": {
              "name": { "minLength": 1 }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "development": {
            "properties": {
              "localAdminSeed": { "const": true }
            }
          }
        }
      },
      "then": {
        "properties": {
          "runtime": {
            "properties": {
              "environment": { "enum": ["development", "test"] }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "httpOrigin": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(https://[^/?#]+|http://(localhost|127\\.0\\.0\\.1|\\[::1\\])(?::[0-9]+)?)$"
    },
    "namespace": {
      "type": "string",
      "minLength": 1,
      "maxLength": 63,
      "pattern": "^[a-z0-9](?:[-a-z0-9]*[a-z0-9])?$"
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "tag", "pullPolicy"],
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string" },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      }
    },
    "workload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["image", "replicas", "resources"],
      "properties": {
        "image": { "$ref": "#/$defs/image" },
        "replicas": { "type": "integer", "minimum": 1 },
        "resources": { "type": "object" }
      }
    },
    "workloadWithPort": {
      "$ref": "#/$defs/workload"
    }
  }
}
