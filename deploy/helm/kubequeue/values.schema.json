{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": false,
      "required": ["create", "name"],
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" }
      }
    },
    "config": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "watchNamespaces",
        "globalConcurrency",
        "namespaceConcurrency",
        "adminToken",
        "adminTokenExistingSecret",
        "adminTokenExistingSecretKey"
      ],
      "properties": {
        "watchNamespaces": { "type": "string" },
        "globalConcurrency": { "type": "integer", "minimum": 1 },
        "namespaceConcurrency": { "type": "integer", "minimum": 1 },
        "adminToken": { "type": "string" },
        "adminTokenExistingSecret": { "type": "string" },
        "adminTokenExistingSecretKey": { "type": "string", "minLength": 1 }
      }
    },
    "database": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "existingSecret", "existingSecretKey"],
      "properties": {
        "url": { "type": "string" },
        "existingSecret": { "type": "string" },
        "existingSecretKey": { "type": "string", "minLength": 1 }
      }
    },
    "networkPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "properties": { "enabled": { "type": "boolean" } }
    },
    "api": { "$ref": "#/$defs/workloadWithPort" },
    "worker": { "$ref": "#/$defs/workload" },
    "web": { "$ref": "#/$defs/workloadWithPort" }
  },
  "required": ["api", "worker", "web", "serviceAccount", "config", "database", "networkPolicy"],
  "$defs": {
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "tag", "pullPolicy"],
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string" },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      }
    },
    "workload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["image", "replicas", "resources"],
      "properties": {
        "image": { "$ref": "#/$defs/image" },
        "replicas": { "type": "integer", "minimum": 1 },
        "resources": { "type": "object" }
      }
    },
    "workloadWithPort": {
      "$ref": "#/$defs/workload"
    }
  }
}
