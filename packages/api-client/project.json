{
  "name": "api-client",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/api-client/src",
  "implicitDependencies": ["api-contract"],
  "tags": ["type:lib", "scope:shared"],
  "targets": {
    "generate": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/src/generated.ts"],
      "options": {
        "command": "pnpm exec openapi-typescript packages/api-contract/openapi/openapi.yaml -o packages/api-client/src/generated.ts"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "pnpm --filter @kubequeue/api-client build"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec eslint packages/api-client"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --filter @kubequeue/api-client typecheck"
      }
    }
  }
}
