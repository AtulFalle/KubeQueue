{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "defaultBase": "master",
  "nxCloudId": "6a5b9bb0b60585f77b3a165b",
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "production": [
      "default",
      "!{projectRoot}/**/*.spec.*",
      "!{projectRoot}/**/*.test.*",
      "!{projectRoot}/vitest.config.*"
    ],
    "go": [
      "default",
      "!{projectRoot}/coverage.out",
      { "runtime": "go version" },
      { "runtime": "go env GOOS GOARCH" }
    ],
    "goProduction": [
      "production",
      "!{projectRoot}/**/*_test.go",
      "!{projectRoot}/coverage.out",
      { "runtime": "go version" },
      { "runtime": "go env GOOS GOARCH" }
    ],
    "sharedGlobals": [
      "{workspaceRoot}/nx.json",
      {
        "json": "{workspaceRoot}/package.json",
        "fields": ["packageManager", "engines", "dependencies", "devDependencies"]
      },
      "{workspaceRoot}/pnpm-lock.yaml",
      "{workspaceRoot}/tsconfig.base.json",
      "{workspaceRoot}/go.work",
      "{workspaceRoot}/go.work.sum"
    ]
  },
  "targetDefaults": {
    "build": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"]
    },
    "lint": {
      "cache": true,
      "inputs": ["default", "^production"]
    },
    "test": {
      "cache": true,
      "inputs": ["default", "^production"]
    },
    "typecheck": {
      "cache": true,
      "inputs": ["default", "^production"]
    },
    "format-check": {
      "cache": true,
      "inputs": ["default", "^production"]
    },
    "dev": {
      "cache": false,
      "continuous": true
    }
  },
  "plugins": [],
  "analytics": false
}
